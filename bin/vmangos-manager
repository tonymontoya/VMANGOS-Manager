#!/usr/bin/env bash
#
# VMANGOS Manager - Main CLI Entry Point
# Unified interface for server control and configuration management
#

set -euo pipefail

# ============================================================================
# GLOBALS
# ============================================================================

readonly VERSION="0.1.0"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly LIB_DIR="$SCRIPT_DIR/../lib"

# Global options
VERBOSE=0
OUTPUT_FORMAT="text"
CONFIG_FILE="${MANAGER_CONFIG:-/opt/mangos/manager/config/manager.conf}"

# ============================================================================
# USAGE
# ============================================================================

show_help() {
    cat << 'EOF'
VMANGOS Manager - Server Management Tool
Version: 0.1.0

USAGE:
    vmangos-manager [GLOBAL_OPTIONS] <COMMAND> [SUBCOMMAND_OPTIONS]

GLOBAL OPTIONS:
    -c, --config FILE      Configuration file path (default: /opt/mangos/manager/config/manager.conf)
    -v, --verbose          Enable verbose output
    -f, --format FORMAT    Output format: text | json (default: text)
    -h, --help             Show this help message
    --version              Show version information

COMMANDS:
    server [start|stop|restart|status] [OPTIONS]
        Control server services
        
        start [--wait]
            Start auth and world services
            --wait    Wait for services to be ready
            
        stop [--graceful|--force]
            Stop services (world first, then auth)
            --graceful  Graceful shutdown (default)
            --force     Force kill
            
        restart
            Restart all services
            
        status [--format json]
            Show service status and player count

    config [create|validate|show]
        Configuration management
        
        create [--path PATH]
            Create default configuration file
            
        validate [--format json]
            Validate configuration file
            
        show [--format json]
            Display current configuration

EXAMPLES:
    # Start server with verbose output
    vmangos-manager --verbose server start --wait
    
    # Check status as JSON
    vmangos-manager --format json server status
    
    # Create config
    vmangos-manager config create
    
    # Validate config
    vmangos-manager config validate

EXIT CODES:
    0   Success
    1   General error
    2   Invalid arguments
    3   Not root (for privileged operations)
    4   Service error
    5   Config error
EOF
}

show_version() {
    echo "VMANGOS Manager version $VERSION"
}

# ============================================================================
# ARGUMENT PARSING (Robust getopt-style parsing)
# ============================================================================

# Parse global options first
parse_global_options() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -f|--format)
                if [[ -n "${2:-}" ]]; then
                    OUTPUT_FORMAT="$2"
                    shift 2
                else
                    echo "Error: --format requires an argument" >&2
                    exit 2
                fi
                ;;
            -c|--config)
                if [[ -n "${2:-}" ]]; then
                    CONFIG_FILE="$2"
                    shift 2
                else
                    echo "Error: --config requires an argument" >&2
                    exit 2
                fi
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --version)
                show_version
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Error: Unknown option: $1" >&2
                exit 2
                ;;
            *)
                break
                ;;
        esac
    done
}

# ============================================================================
# COMMAND HANDLERS
# ============================================================================

# Source libraries (lazy init - no privileged ops)
source "$LIB_DIR/common.sh"
source "$LIB_DIR/config.sh"
source "$LIB_DIR/server.sh"

# Set globals in sourced libraries
VERBOSE="$VERBOSE"
CONFIG_FILE="$CONFIG_FILE"
SKIP_ROOT_INIT=1  # Prevent privileged ops during library loading

cmd_server() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        start)
            local wait=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --wait) wait=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_start "$wait"
            ;;
            
        stop)
            local graceful=true force=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --graceful) graceful=true; shift ;;
                    --force) force=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_stop "$graceful" "$force"
            ;;
            
        restart)
            server_restart
            ;;
            
        status)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            
            if [[ "$fmt" == "json" ]]; then
                server_status_json
            else
                server_status_text
            fi
            ;;
            
        *)
            echo "Error: Unknown server subcommand: $subcmd" >&2
            echo "Valid subcommands: start, stop, restart, status" >&2
            exit 2
            ;;
    esac
}

cmd_config() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        create)
            local path=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --path) path="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            
            if [[ -n "$path" ]]; then
                config_create "$path"
            else
                config_create
            fi
            ;;
            
        validate)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_validate "$CONFIG_FILE" "$fmt"
            ;;
            
        show)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_show "$CONFIG_FILE" "$fmt"
            ;;
            
        *)
            echo "Error: Unknown config subcommand: $subcmd" >&2
            echo "Valid subcommands: create, validate, show" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    # Parse global options
    parse_global_options "$@"
    
    # Get command
    if [[ $# -eq 0 ]]; then
        echo "Error: No command specified" >&2
        show_help >&2
        exit 2
    fi
    
    local cmd="$1"
    shift
    
    case "$cmd" in
        server)
            cmd_server "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo "Error: Unknown command: $cmd" >&2
            show_help >&2
            exit 2
            ;;
    esac
}

main "$@"
